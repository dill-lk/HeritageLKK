{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HeritageLK",
  "version": "0.1.0",
  "identifier": "lk.heritagelk.mobile",
  "build": {
    "frontendDist": "../dist/spa",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build:client"
  },
  "app": {
    "windows": [
      {
        "title": "HeritageLK",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
